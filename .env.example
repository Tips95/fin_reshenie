# === Timeweb Cloud (App Platform + Managed PostgreSQL) ===

# Подключение к Managed PostgreSQL 16 в Timeweb (sslmode=verify-full)
DATABASE_URL=postgresql://gen_user:ВАШ_ПАРОЛЬ@ec20aee5d058cc100363b5a2.twc1.net:5432/default_db?sslmode=verify-full

# Сгенерируйте длинный случайный ключ (минимум 32 символа)
SECRET_KEY=replace-with-long-random-secret

# Ваш домен (технический домен Timeweb или свой)
CORS_ORIGINS=["https://your-app.timeweb.cloud"]

# Frontend ходит в API через nginx на том же домене
NEXT_PUBLIC_API_URL=/api

# Timeweb App Platform: нельзя 80/443, используйте 9000
NGINX_PORT=9000

# Первый запуск: true (создаст admin@reshenie.local и retail-аккаунты)
# После успешного деплоя можно поставить false
RUN_SEED=true

# === Локальный Docker (docker-compose.local.yml) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rassrochka
